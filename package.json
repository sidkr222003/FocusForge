{
  "name": "focusforge",
  "displayName": "FocusForge: Coding Session Tracker",
  "description": "A local-first VS Code productivity dashboard for focus time, Pomodoro cycles, projects, GitHub issues, commits, planner sessions, reports, and AI insights.",
  "version": "1.1.0",
  "publisher": "devtoolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidkr222003/FocusForge.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "SCM Providers",
    "Education",
    "Other"
  ],
  "keywords": [
    "productivity",
    "focus",
    "pomodoro",
    "time tracking",
    "coding sessions",
    "github",
    "git",
    "issues",
    "commits",
    "analytics",
    "deep work",
    "planner",
    "reports",
    "ai insights",
    "students"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onView:devToolkit.sessionTracker",
    "onView:devToolkit.issueView",
    "onView:devToolkit.focusSounds",
    "onCommand:devToolkit.startSession",
    "onCommand:devToolkit.endSession",
    "onCommand:devToolkit.openSessionDashboard",
    "onCommand:devToolkit.viewAchievements",
    "onCommand:devToolkit.viewHistory",
    "onCommand:devToolkit.addSessionNote",
    "onCommand:devToolkit.openJournal",
    "onCommand:devToolkit.startDeepWorkMode",
    "onCommand:devToolkit.endDeepWorkMode",
    "onCommand:devToolkit.exportSessionData",
    "onCommand:devToolkit.resetToday",
    "onCommand:devToolkit.setDailyGoal",
    "onCommand:devToolkit.planner.exportIcs",
    "onCommand:devToolkit.toggleSessionTracking",
    "onCommand:devToolkit.issues.refresh",
    "onCommand:devToolkit.issues.connectGitHub",
    "onCommand:devToolkit.issues.disconnectGitHub",
    "onCommand:devToolkit.issues.newIssue",
    "onCommand:devToolkit.issues.generateReport",
    "onCommand:devToolkit.issues.generateReportLast",
    "onCommand:devToolkit.issues.exportLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devToolkit",
          "title": "Session Tracker",
          "icon": "images/activity-icon.svg"
        }
      ]
    },
    "views": {
      "devToolkit": [
        {
          "type": "webview",
          "id": "devToolkit.sessionTracker",
          "name": "Session Tracker",
          "retainContextWhenHidden": true
        },
        {
          "type": "webview",
          "id": "devToolkit.issueView",
          "name": "Issue Log",
          "retainContextWhenHidden": true
        },
        {
          "type": "webview",
          "id": "devToolkit.focusSounds",
          "name": "Focus Sounds",
          "retainContextWhenHidden": true
        }
      ]
    },
    "submenus": [
      {
        "id": "devToolkit.sessionNotesMenu",
        "label": "Session Notes"
      }
    ],
    "commands": [
      {
        "command": "devToolkit.startSession",
        "title": "Session Tracker: Start Session",
        "icon": "$(play)"
      },
      {
        "command": "devToolkit.endSession",
        "title": "Session Tracker: End Session",
        "icon": "$(debug-stop)"
      },
      {
        "command": "devToolkit.openSessionDashboard",
        "title": "Session Tracker: Open Dashboard"
      },
      {
        "command": "devToolkit.viewAchievements",
        "title": "Session Tracker: View Achievements"
      },
      {
        "command": "devToolkit.viewHistory",
        "title": "Session Tracker: View History"
      },
      {
        "command": "devToolkit.addSessionNote",
        "title": "Session Tracker: Add Session Note"
      },
      {
        "command": "devToolkit.openJournal",
        "title": "Session Tracker: Open Journal"
      },
      {
        "command": "devToolkit.startDeepWorkMode",
        "title": "Session Tracker: Start Deep Work Mode"
      },
      {
        "command": "devToolkit.endDeepWorkMode",
        "title": "Session Tracker: End Deep Work Mode"
      },
      {
        "command": "devToolkit.exportSessionData",
        "title": "Session Tracker: Export Data"
      },
      {
        "command": "devToolkit.resetToday",
        "title": "Session Tracker: Reset Today"
      },
      {
        "command": "devToolkit.setDailyGoal",
        "title": "Session Tracker: Set Daily Goal"
      },
      {
        "command": "devToolkit.planner.exportIcs",
        "title": "Session Tracker: Export Planned Sessions (.ics)"
      },
      {
        "command": "devToolkit.toggleSessionTracking",
        "title": "Session Tracker: Toggle Tracking"
      },
      {
        "command": "devToolkit.issues.refresh",
        "title": "Issues: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "devToolkit.issues.connectGitHub",
        "title": "Issues: Connect GitHub Account"
      },
      {
        "command": "devToolkit.issues.disconnectGitHub",
        "title": "Issues: Disconnect GitHub Account"
      },
      {
        "command": "devToolkit.issues.newIssue",
        "title": "Issues: Create New Issue"
      },
      {
        "command": "devToolkit.issues.generateReport",
        "title": "Issues: Generate Weekly Report"
      },
      {
        "command": "devToolkit.issues.generateReportLast",
        "title": "Issues: Generate Last Week's Report"
      },
      {
        "command": "devToolkit.issues.exportLog",
        "title": "Issues: Export Completion Log (JSON/CSV)"
      }
    ],
    "configuration": {
      "title": "Session Tracker",
      "properties": {
        "devToolkit.sessionTracker.dailyGoalMinutes": {
          "type": "number",
          "default": 120,
          "minimum": 15,
          "maximum": 720,
          "description": "Daily coding goal in minutes."
        },
        "devToolkit.sessionTracker.idleThresholdMinutes": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 30,
          "description": "Minutes of inactivity before marking as idle."
        },
        "devToolkit.sessionTracker.idleDetection": {
          "type": "boolean",
          "default": true,
          "description": "Enable idle detection."
        },
        "devToolkit.sessionTracker.engagedThresholdSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "Seconds since last activity to count as engaged for efficiency."
        },
        "devToolkit.sessionTracker.flowStateThresholdMinutes": {
          "type": "number",
          "default": 25,
          "minimum": 5,
          "maximum": 120,
          "description": "Minutes of continuous focus to enter flow state."
        },
        "devToolkit.sessionTracker.breakReminderInterval": {
          "type": "number",
          "default": 45,
          "minimum": 15,
          "maximum": 120,
          "description": "Minutes between break reminders."
        },
        "devToolkit.sessionTracker.statusBarFormat": {
          "type": "string",
          "default": "timeAndStreak",
          "enum": [
            "timeAndStreak",
            "timeAndLanguage",
            "iconOnly"
          ],
          "description": "Status bar display format."
        },
        "devToolkit.sessionTracker.focusScore": {
          "type": "object",
          "default": {
            "enabled": true,
            "showInStatusBar": true
          },
          "description": "Focus score configuration."
        },
        "devToolkit.sessionTracker.deepWork": {
          "type": "object",
          "default": {
            "defaultDurationMinutes": 50,
            "hideActivityBar": true,
            "hideStatusBar": false,
            "muteNotifications": true
          },
          "description": "Deep Work Mode preferences."
        },
        "devToolkit.sessionTracker.notifications": {
          "type": "object",
          "default": {
            "breakReminders": true,
            "goalReminders": true,
            "achievementToasts": true
          },
          "description": "Notification preferences."
        },
        "devToolkit.sessionTracker.pomodoro": {
          "type": "object",
          "default": {
            "enabled": true,
            "workMinutes": 25,
            "shortBreakMinutes": 5,
            "longBreakMinutes": 15,
            "autoAdvance": true,
            "sound": "bell"
          },
          "description": "Pomodoro mode configuration."
        },
        "devToolkit.sessionTracker.projects": {
          "type": "object",
          "default": {
            "enabled": true,
            "useGitRemote": true
          },
          "description": "Project analytics preferences."
        },
        "devToolkit.sessionTracker.planner": {
          "type": "object",
          "default": {
            "enabled": true,
            "reminderMinutesBefore": 5,
            "exportIcs": true
          },
          "description": "Session planner preferences."
        },
        "devToolkit.sessionTracker.audio": {
          "type": "object",
          "default": {
            "enabled": false,
            "defaultTrack": "rain",
            "volume": 0.4,
            "autoStartWithSession": false
          },
          "description": "Ambient focus audio preferences."
        },
        "devToolkit.sessionTracker.reports": {
          "type": "object",
          "default": {
            "enabled": true,
            "format": "markdown",
            "outputPath": ".vscode/session-reports",
            "autoGenerate": true
          },
          "description": "Weekly and monthly report preferences."
        },
        "devToolkit.sessionTracker.leaderboard": {
          "type": "object",
          "default": {
            "gistId": "",
            "teamGistIds": [],
            "name": "",
            "avatar": "◆"
          },
          "description": "Opt-in GitHub Gist leaderboard preferences."
        },
        "devToolkit.sessionTracker.aiInsights": {
          "type": "object",
          "default": {
            "enabled": false,
            "model": "openai/gpt-4.1-mini",
            "generateOn": "sunday"
          },
          "description": "Opt-in GitHub Models weekly insight preferences. Uses the existing stored GitHub token."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "devToolkit.startSession"
        },
        {
          "command": "devToolkit.endSession"
        },
        {
          "command": "devToolkit.openSessionDashboard"
        },
        {
          "command": "devToolkit.viewAchievements"
        },
        {
          "command": "devToolkit.viewHistory"
        },
        {
          "command": "devToolkit.addSessionNote"
        },
        {
          "command": "devToolkit.openJournal"
        },
        {
          "command": "devToolkit.startDeepWorkMode"
        },
        {
          "command": "devToolkit.endDeepWorkMode"
        },
        {
          "command": "devToolkit.exportSessionData"
        },
        {
          "command": "devToolkit.resetToday"
        },
        {
          "command": "devToolkit.setDailyGoal"
        },
        {
          "command": "devToolkit.planner.exportIcs"
        },
        {
          "command": "devToolkit.toggleSessionTracking"
        }
      ],
      "view/title": [
        {
          "submenu": "devToolkit.sessionNotesMenu",
          "when": "view == devToolkit.sessionTracker",
          "group": "navigation"
        },
        {
          "command": "devToolkit.issues.refresh",
          "when": "view == devToolkit.issueView",
          "group": "navigation"
        }
      ],
      "devToolkit.sessionNotesMenu": [
        {
          "command": "devToolkit.addSessionNote",
          "group": "1_notes"
        },
        {
          "command": "devToolkit.openJournal",
          "group": "1_notes"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "tsc -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@vscode/codicons": "0.0.36",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  }
}
