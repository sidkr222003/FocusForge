{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile",
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "Attach to Extension Host",
      "type": "extensionHost",
      "request": "attach",
      "port": 9222,
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "sourceMaps": true
    }
  ]
}
